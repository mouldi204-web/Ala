# ================== SETTINGS ==================
TELEGRAM_TOKEN = "8439548325:AAHOBBHy7EwcX3J5neIaf6iJuSjyGJCuZ68"
TELEGRAM_CHAT_ID = "5067771509"

# Trading parameters
INITIAL_BALANCE = 1000
MAX_OPEN_TRADES = 10
PROFIT_TARGETS = [3, 6, 10]           # أهداف متعددة: 3%, 6%, 10%
PROFIT_TARGET_PARTS = [0.4, 0.3, 0.3] # 40%, 30%, 30% من حجم الصفقة
STOP_LOSS = -3
TRAILING_STOP_ACTIVATION = 2
TRAILING_STOP_DISTANCE = 1.5
BREAKEVEN_ACTIVATION = 2              # تفعيل وقف الخسارة المتعادل عند +2%
MIN_SCORE_TO_TRADE = 75
COOLDOWN_HOURS = 24
DAILY_LOSS_LIMIT = 50                 # حد الخسارة اليومي بالدولار
MAX_VOLATILITY = 10                   # تجنب العملات ذات التقلب > 10%
ACTIVE_HOURS_START = 12               # 12 ظهراً (توقيت مكة)
ACTIVE_HOURS_END = 20                 # 8 مساءً

USE_TESTNET = True
STABLE_COINS = ['USDC', 'USDT', 'BUSD', 'DAI', 'TUSD', 'FDUSD']

# ================== GLOBALS ==================
balance = INITIAL_BALANCE
open_trades = {}
closed_trades = []
scanning = False
auto_traded_recently = {}
start_time = time.time()
trailing = {}
detected_coins = {}
coin_history = {}
daily_loss = 0
last_reset_date = datetime.now().date()
last_update_id = 0

# ================== INIT CCXT ==================
exchange = ccxt.gateio({
    'enableRateLimit': True,
    'rateLimit': 1200,
    'options': {'defaultType': 'spot'},
})
if USE_TESTNET:
    exchange.set_sandbox_mode(True)

# ================== TELEGRAM ==================
def send_telegram(text, chat_id=None):
    target = chat_id or TELEGRAM_CHAT_ID
    url = f"https://api.telegram.org/bot{TELEGRAM_TOKEN}/sendMessage"
    data = json.dumps({"chat_id": target, "text": text, "parse_mode": "HTML"}).encode()
    try:
        req = urllib.request.Request(url, data=data, headers={"Content-Type": "application/json"})
        urllib.request.urlopen(req, timeout=10)
    except Exception as e:
        print("Telegram error:", e)

# ================== PRICE & DATA ==================
def get_price(symbol):
    try:
        ticker = exchange.fetch_ticker(f"{symbol}/USDT")
        return ticker['last']
    except:
        return 0

def get_24h_data(symbol):
    try:
        ticker = exchange.fetch_ticker(f"{symbol}/USDT")
        return {
            'price': ticker['last'],
            'change': ticker.get('percentage', 0),
            'volume': ticker.get('quoteVolume', 0),
            'high': ticker.get('high', 0),
            'low': ticker.get('low', 0),
            'bid': ticker.get('bid', 0),
            'ask': ticker.get('ask', 0),
        }
    except:
        return None

def get_all_prices():
    try:
        tickers = exchange.fetch_tickers()
        prices = {}
        for sym, data in tickers.items():
            if sym.endswith('/USDT'):
                symbol = sym.replace('/USDT', '')
                if symbol in STABLE_COINS:
                    continue
                prices[symbol] = {
                    'price': data['last'],
                    'change': data.get('percentage', 0),
                    'volume': data.get('quoteVolume', 0),
                    'high': data.get('high', 0),
                    'low': data.get('low', 0),
                    'bid': data.get('bid', 0),
                    'ask': data.get('ask', 0),
                }
        return prices
    except Exception as e:
        print("Price error:", e)
        return {}

def fetch_ohlcv(symbol, timeframe='1h', limit=100):
    try:
        ohlcv = exchange.fetch_ohlcv(f"{symbol}/USDT", timeframe=timeframe, limit=limit)
        return ohlcv
    except:
        return []

# ================== TECHNICAL INDICATORS ==================
def calculate_rsi(ohlcv, period=14):
    closes = [c[4] for c in ohlcv]
    if len(closes) < period + 1:
        return 50
    gains, losses = [], []
    for i in range(1, len(closes)):
        diff = closes[i] - closes[i-1]
        if diff > 0:
            gains.append(diff)
            losses.append(0)
        else:
            gains.append(0)
            losses.append(abs(diff))
    avg_gain = sum(gains[-period:]) / period
    avg_loss = sum(losses[-period:]) / period
    if avg_loss == 0:
        return 100
    rs = avg_gain / avg_loss
    return 100 - (100 / (1 + rs))

def calculate_macd(ohlcv, fast=12, slow=26):
    closes = [c[4] for c in ohlcv]
    if len(closes) < slow:
        return 0, 0
    ema_fast = sum(closes[-fast:]) / fast
    ema_slow = sum(closes[-slow:]) / slow
    return ema_fast - ema_slow, 0

def calculate_bb_width(ohlcv, period=20):
    closes = [c[4] for c in ohlcv[-period:]]
    if len(closes) < period:
        return 0.1
    mean = sum(closes) / period
    variance = sum((x - mean) ** 2 for x in closes) / period
    std = variance ** 0.5
    upper = mean + 2 * std
    lower = mean - 2 * std
    return (upper - lower) / mean if mean != 0 else 0.1

# ================== ENHANCED SCORE (14 CRITERIA) ==================
def calculate_score(symbol, data, ohlcv=None, btc_change=None, coin_win_rate=None):
    score = 0
    details = []
    price = data['price']
    change = data['change']
    volume = data['volume']
    high = data['high']
    low = data['low']
    bid = data.get('bid', price)
    ask = data.get('ask', price)

    # 1. الزخم السعري (25)
    if change > 10: score += 25
    elif change > 8: score += 22
    elif change > 6: score += 18
    elif change > 4: score += 14
    elif change > 2: score += 8
    elif change > 1: score += 4

    # 2. حجم التداول المطلق (15)
    if volume > 200_000_000: score += 15
    elif volume > 100_000_000: score += 12
    elif volume > 50_000_000: score += 9
    elif volume > 20_000_000: score += 6
    elif volume > 10_000_000: score += 3
    elif volume > 5_000_000: score += 1

    # 3. السعر المنخفض (10)
    if price < 0.05: score += 10
    elif price < 0.1: score += 8
    elif price < 0.5: score += 5
    elif price < 1: score += 3
    elif price < 2: score += 1

    # 4. التقلب (10) – مع خصم إذا كان عالياً جداً
    if high > 0 and low > 0:
        volatility = ((high - low) / low) * 100
        if volatility > MAX_VOLATILITY:
            score -= 10
            details.append(f"High volatility {volatility:.1f}%: -10")
        elif volatility > 12: score += 10
        elif volatility > 10: score += 8
        elif volatility > 8: score += 5
        elif volatility > 5: score += 3

    # 5. الحجم النسبي (10) – يعتمد على ohlcv
    if ohlcv and len(ohlcv) >= 20:
        volumes = [c[5] for c in ohlcv[-21:-1]]
        avg_volume = sum(volumes) / len(volumes) if volumes else 1
        vol_ratio = volume / avg_volume if avg_volume > 0 else 1
        if vol_ratio > 2: score += 10
        elif vol_ratio > 1.5: score += 6
        elif vol_ratio > 1.2: score += 3

    # 6. RSI (+/- 8)
    if ohlcv and len(ohlcv) >= 15:
        rsi = calculate_rsi(ohlcv)
        if rsi > 70: score -= 8
        elif rsi < 30: score += 8
        elif 30 <= rsi <= 50: score += 4

    # 7. ترتيب EMA (6)
    if ohlcv and len(ohlcv) >= 50:
        closes = [c[4] for c in ohlcv]
        ema9 = sum(closes[-9:]) / 9
        ema21 = sum(closes[-21:]) / 21
        ema50 = sum(closes[-50:]) / 50
        if price > ema9 > ema21 > ema50: score += 6

    # 8. MACD (6)
    if ohlcv and len(ohlcv) >= 26:
        macd, _ = calculate_macd(ohlcv)
        if macd > 0: score += 6

    # 9. Bollinger Squeeze (5)
    if ohlcv and len(ohlcv) >= 20:
        if calculate_bb_width(ohlcv) < 0.05: score += 5

    # 10. المقاومة القريبة (-5)
    if ohlcv and len(ohlcv) >= 20:
        highs = [c[2] for c in ohlcv[-20:]]
        resistance = max(highs)
        if (resistance - price) / price < 0.02: score -= 5

    # 11. السيولة (-4)
    if bid > 0 and ask > 0:
        spread = (ask - bid) / bid
        if spread > 0.002: score -= 4

    # 12. تصنيف العملة السابق (0-5)
    if coin_win_rate is not None:
        if coin_win_rate > 70: score += 5
        elif coin_win_rate > 60: score += 3
        elif coin_win_rate > 50: score += 1

    # 13. تأثير البيتكوين (عامل ضرب)
    if btc_change is not None:
        if btc_change < -2: score = score * 0.7
        elif btc_change > 2: score = score * 1.1

    # 14. وقت التداول (عامل ضرب)
    hour = datetime.now().hour
    if hour < ACTIVE_HOURS_START or hour > ACTIVE_HOURS_END:
        score = score * 0.8

    final_score = max(0, min(100, int(score)))
    return final_score

# ================== DYNAMIC POSITION SIZING ==================
def get_position_size(score, volatility=None):
    base = 50  # الدولار الأساسي
    if score >= 90:
        size = base * 1.5   # 75$
    elif score >= 75:
        size = base         # 50$
    else:
        size = base * 0.5   # 25$
    # تعديل حسب التقلب (إذا كان مرتفعاً، نقلل الحجم)
    if volatility and volatility > 8:
        size = size * 0.7
    return max(20, min(100, size))

# ================== DAILY LOSS CHECK ==================
def check_daily_loss():
    global daily_loss, last_reset_date
    today = datetime.now().date()
    if today != last_reset_date:
        daily_loss = 0
        last_reset_date = today
    return daily_loss < DAILY_LOSS_LIMIT

# ================== TRADING LOGIC ==================
def can_open():
    return len(open_trades) < MAX_OPEN_TRADES and balance >= 20 and check_daily_loss()

def is_tradable(symbol):
    if symbol in open_trades: return False
    if symbol in auto_traded_recently:
        last = auto_traded_recently[symbol]
        if (datetime.now() - last).total_seconds() < COOLDOWN_HOURS * 3600:
            return False
    return True

def open_trade(symbol, price, score, volatility):
    global balance
    if not can_open(): return False
    if not is_tradable(symbol): return False
    size = get_position_size(score, volatility)
    qty = size / price
    trade = {
        "symbol": symbol,
        "entry_price": price,
        "entry_time": datetime.now(),
        "amount": size,
        "quantity": qty,
        "score": score,
        "highest": price,
        "status": "OPEN",
        "targets_hit": 0,
        "breakeven_activated": False
    }
    open_trades[symbol] = trade
    balance -= size
    auto_traded_recently[symbol] = datetime.now()
    return True

def close_trade(symbol, reason, close_percent=1.0):
    global balance, daily_loss
    if symbol not in open_trades: return
    trade = open_trades[symbol]
    cur = get_price(symbol)
    if cur == 0: return
    ret = ((cur - trade['entry_price']) / trade['entry_price']) * 100
    # حساب الربح/الخسارة بناءً على النسبة المغلقة فقط
    closed_amount = trade['amount'] * close_percent
    closed_qty = trade['quantity'] * close_percent
    pnl = (cur - trade['entry_price']) * closed_qty
    # تحديث الصفقة المتبقية
    trade['amount'] -= closed_amount
    trade['quantity'] -= closed_qty
    # تسجيل الجزء المغلق كصفقة منفصلة
    closed_trade = {
        "symbol": symbol,
        "entry_price": trade['entry_price'],
        "entry_time": trade['entry_time'],
        "exit_price": cur,
        "exit_time": datetime.now(),
        "final_return": ret,
        "profit_loss": pnl,
        "exit_reason": reason,
        "amount": closed_amount,
        "score": trade['score']
    }
    closed_trades.append(closed_trade)
    balance += closed_amount + pnl
    if pnl < 0:
        daily_loss += abs(pnl)
    # إذا تم إغلاق كل الصفقة، حذفها
    if trade['amount'] <= 0:
        del open_trades[symbol]
        if symbol in trailing: del trailing[symbol]
    return True

def monitor_trades():
    for sym in list(open_trades.keys()):
        cur = get_price(sym)
        if cur == 0: continue
        trade = open_trades[sym]
        ret = ((cur - trade['entry_price']) / trade['entry_price']) * 100
        if cur > trade['highest']:
            trade['highest'] = cur

        # ---- Breakeven Stop ----
        if not trade.get('breakeven_activated') and ret >= BREAKEVEN_ACTIVATION:
            # تحريك وقف الخسارة إلى نقطة الدخول
            trade['breakeven_activated'] = True
            send_telegram(f"🔒 Breakeven activated for {sym} (entry protected)")

        # ---- Multiple Take Profits ----
        # نتحقق من الأهداف بالترتيب
        for i, target in enumerate(PROFIT_TARGETS):
            if trade.get('targets_hit', 0) <= i and ret >= target:
                close_percent = PROFIT_TARGET_PARTS[i]
                close_trade(sym, f"TP_{target}%", close_percent)
                trade['targets_hit'] = i+1
                send_telegram(f"✅ TP {target}% hit for {sym} | Closed {close_percent*100:.0f}% of position")
                # بعد الإغلاق الجزئي، نخرج من الحلقة لأن trade قد تغير
                break

        # ---- Trailing Stop (للباقي المتبقي) ----
        if sym in open_trades:  # قد تكون الصفقة أغلقت بالكامل في الـ TP
            trade = open_trades[sym]  # تحديث المرجع
            if sym not in trailing:
                if ret >= TRAILING_STOP_ACTIVATION:
                    trailing[sym] = cur * (1 - TRAILING_STOP_DISTANCE / 100)
                    send_telegram(f"🔒 Trailing active {sym} at ${trailing[sym]:.6f}")
            else:
                if cur <= trailing[sym]:
                    close_trade(sym, "TRAILING", 1.0)
                    send_telegram(f"📉 Trailing closed {sym} | Return: {ret:+.2f}%")
                    continue
                if cur > trade['highest']:
                    trailing[sym] = cur * (1 - TRAILING_STOP_DISTANCE / 100)

        # ---- Hard Stop Loss (للباقي) ----
        if sym in open_trades:
            trade = open_trades[sym]
            if ret <= STOP_LOSS:
                close_trade(sym, "SL", 1.0)
                send_telegram(f"❌ SL {sym} | Return: {ret:+.2f}%")

# ================== AUTO SCAN & TRADE (EVERY 15 MIN) ==================
def scan_and_trade():
    global scanning, detected_coins
    if not check_daily_loss():
        send_telegram("Daily loss limit reached. Auto-trading paused for today.")
        return
    scanning = True
    send_telegram("🔍 Auto scanning Gate.io market (enhanced score)...")
    try:
        btc_data = get_24h_data('BTC')
        btc_change = btc_data['change'] if btc_data else 0
        all_prices = get_all_prices()
        candidates = []
        for sym, data in all_prices.items():
            ohlcv = fetch_ohlcv(sym, timeframe='1h', limit=100)
            win_rate = coin_history.get(sym, {}).get('win_rate', 50)
            score = calculate_score(sym, data, ohlcv, btc_change, win_rate)
            # تخزين في detected_coins
            if sym not in detected_coins:
                detected_coins[sym] = {"best_score": score, "best_price": data['price']}
            else:
                if score > detected_coins[sym]["best_score"]:
                    detected_coins[sym]["best_score"] = score
                    detected_coins[sym]["best_price"] = data['price']
            if score >= MIN_SCORE_TO_TRADE:
                volatility = ((data['high'] - data['low']) / data['low']) * 100 if data['low']>0 else 0
                candidates.append((sym, data['price'], score, volatility))
        candidates.sort(key=lambda x: x[2], reverse=True)
        if candidates:
            msg = "📊 Top candidates:\n"
            for c in candidates[:5]:
                msg += f"{c[0]} | Score {c[2]} | ${c[1]:.6f}\n"
            send_telegram(msg)
            for sym, price, score, vol in candidates[:3]:
                if can_open() and is_tradable(sym):
                    open_trade(sym, price, score, vol)
                    send_telegram(f"✅ AUTO BUY {sym} | Score {score} | Size ${get_position_size(score, vol):.0f} | ${price:.6f}")
        else:
            send_telegram("No candidates found with score >= 75.")
    except Exception as e:
        send_telegram(f"Scan error: {str(e)[:100]}")
    finally:
        scanning = False

def auto_scan_loop():
    while True:
        now = datetime.now()
        wait = 900 - (now.minute % 15) * 60 - now.second
        if wait <= 0: wait += 900
        time.sleep(wait)
        if not scanning:
            scan_and_trade()

def monitor_loop():
    while True:
        monitor_trades()
        time.sleep(30)

# ================== WEEKLY REPORT ==================
def send_weekly_report():
    now = datetime.now()
    # كل يوم اثنين الساعة 9 صباحاً
    if now.weekday() == 0 and now.hour == 9:
        total_trades = len(closed_trades)
        if total_trades == 0: return
        winning = sum(1 for t in closed_trades if t.get('final_return',0) > 0)
        total_pnl = sum(t.get('profit_loss',0) for t in closed_trades)
        win_rate = (winning / total_trades) * 100
        report = f"📊 Weekly Report\nTrades: {total_trades}\nWinning: {winning}\nWin Rate: {win_rate:.1f}%\nTotal PnL: ${total_pnl:+.2f}"
        send_telegram(report)
        time.sleep(3600)  # انتظر ساعة لتجنب التكرار

def start_weekly_scheduler():
    while True:
        send_weekly_report()
        time.sleep(3600)

# ================== WEB DASHBOARD ==================
def get_portfolio_status():
    total_value = balance
    for trade in open_trades.values():
        price = get_price(trade['symbol'])
        if price > 0:
            total_value += trade['quantity'] * price
    realized_pnl = sum(t.get('profit_loss', 0) for t in closed_trades)
    total_pnl = realized_pnl
    winning = sum(1 for t in closed_trades if t.get('final_return', 0) > 0)
    win_rate = (winning / len(closed_trades) * 100) if closed_trades else 0
    return {
        'balance': balance,
        'total_value': total_value,
        'total_pnl': total_pnl,
        'return_pct': (total_pnl / INITIAL_BALANCE) * 100,
        'open_trades': len(open_trades),
        'closed_trades': len(closed_trades),
        'win_rate': win_rate,
        'daily_loss': daily_loss,
        'daily_limit': DAILY_LOSS_LIMIT
    }

class WebHandler(BaseHTTPRequestHandler):
    def do_GET(self):
        self.send_response(200)
        self.send_header('Content-type', 'text/html; charset=utf-8')
        self.end_headers()
        status = get_portfolio_status()
        uptime = (time.time() - start_time) / 3600
        html = f"""
        <!DOCTYPE html>
        <html>
        <head><title>Gate.io Auto Bot</title><meta http-equiv="refresh" content="30"></head>
        <body style="background:#1a1a2e;color:#eee;font-family:Segoe UI;text-align:center;padding:20px">
        <h1>🚀 Gate.io Auto Trading Bot (Enhanced)</h1>
        <p>Status: ✅ ONLINE | Uptime: {uptime:.1f}h</p>
        <p>💰 Balance: ${status['balance']:.2f}</p>
        <p>📈 Total PnL: ${status['total_pnl']:+.2f}</p>
        <p>🟢 Open: {status['open_trades']} | 🔒 Closed: {status['closed_trades']}</p>
        <p>📊 Win Rate: {status['win_rate']:.1f}%</p>
        <p>⚠️ Daily Loss: ${status['daily_loss']:.2f} / ${DAILY_LOSS_LIMIT}</p>
        <p>📅 {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}</p>
        <hr>
        <p>🤖 Auto-scan every 15 min | TP levels: {PROFIT_TARGETS}% | Trailing {TRAILING_STOP_DISTANCE}% | Breakeven @{BREAKEVEN_ACTIVATION}%</p>
        </body>
        </html>
        """
        self.wfile.write(html.encode())
    def log_message(self, format, *args): pass

def start_web():
    port = int(os.environ.get('PORT', 8080))
    HTTPServer(('0.0.0.0', port), WebHandler).serve_forever()

# ================== TELEGRAM COMMANDS ==================
def get_updates(offset=None):
    url = f"https://api.telegram.org/bot{TELEGRAM_TOKEN}/getUpdates"
    if offset:
        url += f"?offset={offset}"
    try:
        with urllib.request.urlopen(url, timeout=30) as r:
            return json.loads(r.read().decode())
    except:
        return {"result": []}

def handle_commands():
    global last_update_id, scanning
    while True:
        try:
            updates = get_updates(last_update_id + 1)
            for upd in updates.get('result', []):
                last_update_id = upd['update_id']
                msg = upd.get('message', {})
                text = msg.get('text', '').lower()
                chat = msg.get('chat', {}).get('id')
                if not chat: continue
                if text == '/start':
                    send_telegram("🤖 Gate.io Enhanced Bot started.\n/status - Info\n/scan - Manual scan\n/portfolio - Details\n/closeall - Close all\n/help", chat)
                elif text == '/status':
                    st = get_portfolio_status()
                    send_telegram(f"💰 Balance: ${st['balance']:.2f}\n📈 Total PnL: ${st['total_pnl']:+.2f}\n🟢 Open: {st['open_trades']}\n🔒 Closed: {st['closed_trades']}\n📊 Win rate: {st['win_rate']:.1f}%\n⚠️ Daily loss: ${st['daily_loss']:.2f}", chat)
                elif text == '/scan':
                    if scanning: send_telegram("Scan already running.", chat)
                    else:
                        send_telegram("Manual scan started.", chat)
                        threading.Thread(target=scan_and_trade, daemon=True).start()
                elif text == '/portfolio':
                    st = get_portfolio_status()
                    msg = f"💰 Balance: ${st['balance']:.2f}\n\n🟢 Open trades:\n"
                    for sym, trade in open_trades.items():
                        cur = get_price(sym)
                        ret = ((cur - trade['entry_price']) / trade['entry_price']) * 100 if cur else 0
                        msg += f"{sym}: {ret:+.1f}% (${trade['entry_price']:.4f})\n"
                    if not open_trades: msg += "No open trades.\n"
                    send_telegram(msg, chat)
                elif text == '/closeall':
                    count = len(open_trades)
                    for sym in list(open_trades.keys()):
                        close_trade(sym, "MANUAL", 1.0)
                    send_telegram(f"Closed {count} trades.", chat)
                elif text == '/help':
                    send_telegram("Commands: /start, /status, /scan, /portfolio, /closeall, /help", chat)
                else:
                    send_telegram("Unknown command. /help", chat)
            time.sleep(1)
        except Exception as e:
            print("Cmd error:", e)
            time.sleep(5)

# ================== MAIN ==================
if __name__ == "__main__":
    print("=" * 60)
    print("🚀 GATE.IO AUTO TRADING BOT - ENHANCED VERSION")
    print(f"Mode: {'TESTNET (Paper Trading)' if USE_TESTNET else 'LIVE Trading'}")
    print(f"Initial balance: ${INITIAL_BALANCE}")
    print(f"Auto-scan every 15 min | Min score: {MIN_SCORE_TO_TRADE}")
    print(f"TP levels: {PROFIT_TARGETS}% | Trailing: {TRAILING_STOP_DISTANCE}% | Breakeven: {BREAKEVEN_ACTIVATION}%")
    print("=" * 60)

    threading.Thread(target=start_web, daemon=True).start()
    threading.Thread(target=auto_scan_loop, daemon=True).start()
    threading.Thread(target=monitor_loop, daemon=True).start()
    threading.Thread(target=start_weekly_scheduler, daemon=True).start()
    handle_commands()
